[Unit]
Description=TE4 Backend (FastAPI)
After=network.target

[Service]
User=www-data
WorkingDirectory=/var/www/te4/backend
EnvironmentFile=/var/www/te4/backend/.env
ExecStart=/var/www/te4/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
